{
  "name": "mtg-proxy-builder",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix client\" \"npm run dev --prefix server\"",
    "lint": "eslint .",
    "electron:dev": "concurrently \"npm run dev --prefix client\" \"tsc -p electron/tsconfig.json && wait-on http://localhost:5173 && cross-env NODE_ENV=development electron -r ts-node/register dist-electron/main.js\"",
    "electron:build": "npm run build --prefix client && npm run build --prefix server && tsc -p electron/tsconfig.json && electron-builder"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^39.2.5",
    "electron-builder": "^25.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.proxiesathome.app",
    "productName": "Proxxied",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist-electron/**/*",
      "client/dist/**/*",
      "server/dist/**/*",
      "server/package.json",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@babel/preset-env": "^7.28.5",
    "axios-retry": "^4.5.0",
    "bottleneck": "^2.19.5",
    "canvas": "^3.2.0",
    "node-fetch": "^3.3.2"
  }
}